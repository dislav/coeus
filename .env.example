# ─────────────────────────────────────────────────────────────
# Coeus — Docker Compose environment template.
#   cp .env.example .env   # then fill in real values
# Compose interpolates ${VAR} when rendering docker-compose.yml; if a value
# contains a literal '$', escape it as '$$'.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────
# These feed BOTH the db container and the auto-built COEUS_POSTGRES_DSN
# (so the app always connects to the db service with the same credentials).
POSTGRES_DB=coeus
POSTGRES_USER=coeus
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Coeus secrets (REQUIRED — app exits at startup if missing) ──
# Generate a 32-byte secret:   openssl rand -hex 32
COEUS_JWT_SECRET=change-me-to-a-random-32-byte-secret

COEUS_AI_VISION_API_KEY=sk-...        # Moonshot / Kimi
COEUS_AI_REVIEWER_API_KEY=sk-...      # DeepSeek

# ── Coeus optional ───────────────────────────────────────────
# Embedder: if unset, semantic dedup is skipped (exact-hash dedup still works).
# COEUS_AI_EMBEDDER_API_KEY=sk-...
# COEUS_AI_EMBEDDER_BASE_URL=

# These already have safe defaults — uncomment only to override:
# COEUS_AI_VISION_BASE_URL=https://api.moonshot.cn/v1
# COEUS_AI_REVIEWER_BASE_URL=https://api.deepseek.com/v1
# COEUS_SERVER_ADDR=:8080
# COEUS_WORKERS_COUNT=4

# CORS — for a browser SPA on a VPS, set specific origins instead of '*'.
# COEUS_CORS_ALLOWED_ORIGINS=https://app.example.com
# COEUS_CORS_ALLOW_CREDENTIALS=false

# Host port to publish. Defaults to 8080. Front it with nginx/Caddy for TLS.
# COEUS_HTTP_PORT=8080
