# Git
.git
.gitignore

# IDE
.idea

# Pre-built binaries (wrong arch for Docker)
coeus

# Documentation and planning artifacts
*.md
docs/

# Agent/skill configuration (not needed at build or runtime).
# NOTE: the repo-root skills/ directory IS required — it is a Go package
# (skills/skills.go) embedded into the binary via go:embed and imported by
# internal/ai/{extractor,verifier}. Do NOT exclude it, or the build fails with
# "no required module provides package .../coeus/skills".
.agents
.opencode
skills-lock.json

# Docker
Dockerfile
.dockerignore

# OS
.DS_Store
